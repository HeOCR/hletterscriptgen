{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:heocr:letter_set:v1",
  "title": "letter_set.v1",
  "description": "Per-writer Hebrew letter-glyph image set produced by hletterscriptgen. Each set groups extracted glyphs by writer identity; each Hebrew letter may have multiple variants drawn from different source scans by the same writer. Rights are carried through from the upstream scan corpus per variant.",
  "type": "object",
  "required": [
    "schema_version",
    "writer_id",
    "writer_provenance",
    "generator",
    "generated_at",
    "upstream",
    "letters",
    "license_summary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "letter_set.v1"
    },
    "writer_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable, repo-unique identifier for the writer this set belongs to."
    },
    "writer_label": {
      "type": "string",
      "description": "Optional human-readable label. Must not be used to carry PII; see docs/letter_set_v1.md."
    },
    "writer_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_repo", "source_entry_ids", "attribution_method"],
      "properties": {
        "source_repo": {
          "type": "string",
          "minLength": 1,
          "description": "Upstream repository identifier, e.g. 'HeOCR/public-domain-hand-written-hebrew-scans'."
        },
        "source_entry_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 },
          "description": "Identifiers of upstream scan entries attributed to this writer. Must be a superset of every variant's source.scan_entry_id."
        },
        "attribution_method": {
          "type": "string",
          "minLength": 1,
          "description": "How writer identity was established (e.g. 'collection_metadata', 'manual_review', 'fixture')."
        },
        "notes": { "type": "string" }
      }
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "config_hash"],
      "properties": {
        "name": { "type": "string", "const": "hletterscriptgen" },
        "version": { "type": "string", "minLength": 1 },
        "config_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "Lowercase SHA-256 hex digest of the canonical-JSON serialization of the resolved generator configuration. See docs/letter_set_v1.md for the exact algorithm."
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "revision"],
      "description": "Pin to the upstream scan corpus revision that this letter set was produced from. Required for reproducibility.",
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1,
          "description": "Upstream repository identifier in 'owner/name' form, e.g. 'HeOCR/public-domain-hand-written-hebrew-scans'."
        },
        "revision": {
          "type": "string",
          "minLength": 1,
          "description": "Upstream revision identifier (typically a git commit SHA, optionally a tag)."
        }
      }
    },
    "letters": {
      "type": "object",
      "description": "Mapping from a single Hebrew letter character (base or final form, U+05D0..U+05EA) to an array of variant entries.",
      "minProperties": 1,
      "additionalProperties": false,
      "patternProperties": {
        "^[א-ת]$": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/variant" }
        }
      }
    },
    "license_summary": {
      "type": "object",
      "description": "Aggregate rights propagation summary. Must equal the set of distinct source.license values across all variants. Per-variant license remains authoritative.",
      "additionalProperties": false,
      "required": ["licenses"],
      "properties": {
        "licenses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/license_id" }
        },
        "notes": { "type": "string" }
      }
    }
  },
  "$defs": {
    "license_id": {
      "type": "string",
      "description": "SPDX or LicenseRef-* identifier accepted by hletterscriptgen rights policy. Extending this set requires a schema change.",
      "enum": [
        "CC0-1.0",
        "PDM-1.0",
        "LicenseRef-Public-Domain-Israel",
        "LicenseRef-Public-Domain-Ukraine",
        "CC-BY-4.0",
        "CC-BY-3.0",
        "CC-BY-SA-4.0",
        "CC-BY-SA-3.0"
      ]
    },
    "variant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "variant_id",
        "asset_path",
        "checksum_sha256",
        "image",
        "source"
      ],
      "properties": {
        "variant_id": {
          "type": "string",
          "minLength": 1
        },
        "asset_path": {
          "type": "string",
          "minLength": 1,
          "description": "POSIX path relative to the letter-set root. Must not start with '/'. The '..' segment ban is enforced by hletterscriptgen.validation cross-field rules, not by this schema.",
          "pattern": "^[^/].+$"
        },
        "checksum_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "image": {
          "type": "object",
          "additionalProperties": false,
          "required": ["width_px", "height_px", "format"],
          "properties": {
            "width_px": { "type": "integer", "minimum": 1 },
            "height_px": { "type": "integer", "minimum": 1 },
            "format": {
              "type": "string",
              "enum": ["png", "webp", "tiff"]
            }
          }
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scan_entry_id", "license", "bbox_in_source"],
          "properties": {
            "scan_entry_id": {
              "type": "string",
              "minLength": 1,
              "description": "Identifier of the upstream scan entry. Must appear in writer_provenance.source_entry_ids."
            },
            "scan_url": {
              "type": "string",
              "format": "uri"
            },
            "license": { "$ref": "#/$defs/license_id" },
            "rights_evidence": {
              "type": "string",
              "description": "Free-form note or URL with rights evidence carried through from upstream."
            },
            "bbox_in_source": {
              "type": "object",
              "additionalProperties": false,
              "required": ["x", "y", "width", "height"],
              "properties": {
                "x": { "type": "integer", "minimum": 0 },
                "y": { "type": "integer", "minimum": 0 },
                "width": { "type": "integer", "minimum": 1 },
                "height": { "type": "integer", "minimum": 1 }
              }
            }
          }
        },
        "extracted_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": { "type": "string" }
      }
    }
  }
}
